{
  "name": "todo-app",
  "version": "1.0.0",
  "description": "时光清单 — 待办 + 复盘 + 习惯",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.todo.shiguangqingdan",
    "productName": "时光清单",
    "directories": { "output": "dist" },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "时光清单"
    }
  }
}
